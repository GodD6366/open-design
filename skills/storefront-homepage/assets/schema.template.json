            "structure": "grid",
            "distribution": "auto_balance",
            "alignment": {
              "horizontal": "full_bleed",
              "edge": "no_padding"
            },
            "spacing": {
              "mode": "whitespace_only",
              "density": "comfortable"
            },
            "grouping": {
              "enabled": true,
              "visual_method": "spacing_only"
            },
            "slots": [
              {
                "id": "left",
                "role": "sub_action",
                "size": "medium",
                "position": "left"
              },
              {
                "id": "right",
                "role": "sub_action",
                "size": "medium",
                "position": "right"
              }
