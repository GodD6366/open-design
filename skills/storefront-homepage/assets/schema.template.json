          },
          "visual_style": {
            "design_principle": "minimal_ui",
            "brand_tone": "premium",
            "color_system": {
              "primary": "#C98C5A",
              "usage": {
                "icon": true,
                "accent": true,
                "background": false
              }
            },
            "icon": {
              "style": "flat_duotone",
              "shape": "rounded",
              "stroke": "none"
            },
            "block": {
              "radius": 22,
              "shadow": "soft"
            },
            "typography": {
              "title_case": "chinese",
              "subtitle_case": "uppercase"
            }
          },
          "content": {
            "mode": "dynamic_binding",
            "source": "slots_mapping",
            "fields": ["icon", "title", "subtitle"],
            "slots_mapping": {
              "left": {
                "icon": "sparkles",
                "title": "到店自取",
                "subtitle": "功能入口"
              },
              "right": {
                "icon": "sparkles",
                "title": "外卖点单",
                "subtitle": "功能入口"
              }
            }
          },
          "constraints": [
            "pure_white_background",
            "no_border",
            "no_divider",
            "no_outline",
            "no_extra_cards",
            "no_floating_elements",
            "no_circle_entries",
            "icon_style_follow_page",
            "white_background_only",
            "no_complex_background",
            "no_background_pattern",
            "no_gradient_background",
            "no_photography_background",
            "no_logo",
            "no_brand_mark",
            "no_shop_slogan"
          ],
          "output": {
            "aspect_ratio": "dynamic",
            "format": "image",
            "target": "mobile_ui"
          }
        }
      }
