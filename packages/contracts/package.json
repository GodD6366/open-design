{
  "name": "@open-design/contracts",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Shared pure TypeScript contracts for the Open Design web/daemon boundary.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./shop-home-page": {
      "types": "./src/prompts/shop-home-page.ts",
      "default": "./src/prompts/shop-home-page.ts"
    },
    "./shop-home-page-tones": {
      "types": "./src/prompts/shop-home-page-tones.ts",
      "default": "./src/prompts/shop-home-page-tones.ts"
    },
    "./shop-home-page-phone-chrome": {
      "types": "./src/shop-home-page-phone-chrome.ts",
      "default": "./src/shop-home-page-phone-chrome.ts"
    },
    "./shop-home-page-reference-regions": {
      "types": "./src/shop-home-page-reference-regions.ts",
      "default": "./src/shop-home-page-reference-regions.ts"
    },
    "./critique": {
      "types": "./src/critique.ts",
      "default": "./src/critique.ts"
    }
  },
  "types": "./src/index.ts",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
